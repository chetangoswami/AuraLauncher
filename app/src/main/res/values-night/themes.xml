<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AestheticLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@android:color/white</item>
        <item name="colorPrimaryVariant">@android:color/white</item>
        <item name="colorOnPrimary">@android:color/black</item>
        <item name="colorSecondary">@android:color/white</item>
        <item name="colorSecondaryVariant">@android:color/white</item>
        <item name="colorOnSecondary">@android:color/black</item>
        
        <!-- Window background and wallpaper support -->
        <item name="android:windowBackground">@android:color/black</item>
        
        <!-- Edge to edge transparent bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>